from PySide6.QtWidgets import QMainWindow, QWidget, QSplitter, QVBoxLayout
from PySide6.QtCore import Qt

class MainWindow(QMainWindow):
    def __init__(self):
        super().__init__()

        self.setWindowTitle("Spike Detect Gui")
        self.resize(1200, 800)

        self.main_splitter = QSplitter(Qt.Orientation.Horizontal)
        
        # Set the splitter as the central widget of the main window
        self.setCentralWidget(self.main_splitter)

        # --- Create the Left and Right Panels ---
        self.left_panel = QWidget()
        self.right_panel = QWidget()

        # TEMPORARY: Let's color them so we can actually see the 15/85 split.
        # We will remove this later once we put real widgets inside them.
        self.left_panel.setStyleSheet("background-color: #2c3e50;")  # Dark Blue/Grey
        self.right_panel.setStyleSheet("background-color: #ecf0f1;") # Light Grey

        # Add panels to the splitter
        self.main_splitter.addWidget(self.left_panel)
        self.main_splitter.addWidget(self.right_panel)

        # --- Apply the 15% / 85% Ratio ---
        self.main_splitter.setStretchFactor(0, 15)  # Index 0 is left_panel
        self.main_splitter.setStretchFactor(1, 85)  # Index 1 is right_panel
